# application-local.yaml (정리 후)
spring:
  datasource:
    url: jdbc:postgresql://localhost:5432/replan
    username: your_db_username
    password: your_db_password
  jpa:
    show-sql: true   # base는 false라서 override 필요
  data:
    redis:
      host: localhost
      port: 6379

jwt:
  secret: your_jwt_secret
  access-expiration: 3600000  # base는 900000이라서 override 필요
